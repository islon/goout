<!-- pages/mine/mine.wxml -->
<view class="container">

  <!-- 头部 -->
  <view class="page-header">
    <view class="header-icon">🔔</view>
    <view class="header-title">我的订阅</view>
    <view class="header-subtitle" wx:if="{{!isEmpty}}">{{subscriptions.length}} 个活动已订阅提醒</view>
  </view>

  <!-- 订阅列表 -->
  <view class="sub-list" wx:if="{{!isEmpty}}">
    <view 
      class="sub-card"
      wx:for="{{subscriptions}}" wx:key="_id"
      bindtap="onActivityTap" data-id="{{item._id}}">

      <view class="card-tags">
        <text class="tag tag-category">{{item.category}}</text>
        <text class="tag {{item._isFree ? 'tag-free' : 'tag-paid'}}">{{item.fee}}</text>
      </view>

      <view class="card-title">{{item.title}}</view>

      <view class="card-row">
        <text class="card-icon">📅</text>
        <text class="card-text">{{item._dateRange}}</text>
      </view>
      <view class="card-row">
        <text class="card-icon">📍</text>
        <text class="card-text">{{item.venue}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <view class="empty-icon">📭</view>
    <view class="empty-text">还没有订阅任何活动</view>
    <view class="empty-hint">去发现感兴趣的亲子活动吧</view>
    <button class="btn-primary empty-btn" bindtap="onExploreTap">浏览活动</button>
  </view>

</view>
