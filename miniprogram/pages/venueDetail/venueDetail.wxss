/* pages/venueDetail/venueDetail.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部信息卡 */
.hero-card {
  background: linear-gradient(135deg, #D4A373 0%, #B8895A 100%);
  padding: 48rpx 32rpx;
  color: white;
}
.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.hero-tags .tag {
  background: rgba(255, 255, 255, 0.2);
  color: white;
}
.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 16rpx;
}
.hero-sub {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 信息卡 */
.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 8rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 163, 115, 0.08);
}
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F5F0E8;
}
.info-row:last-child {
  border-bottom: none;
}
.info-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  margin-top: 4rpx;
}
.info-content {
  flex: 1;
}
.info-label {
  font-size: 24rpx;
  color: #A8A29E;
  margin-bottom: 6rpx;
}
.info-value {
  font-size: 30rpx;
  color: #292524;
}
.info-action {
  padding: 8rpx 24rpx;
  background: #FDF6ED;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #D4A373;
  align-self: center;
}

/* 介绍 / 特色 */
.desc-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 163, 115, 0.08);
}
.desc-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #292524;
  margin-bottom: 20rpx;
}
.desc-text {
  font-size: 28rpx;
  color: #78716C;
  line-height: 1.8;
}
.highlight-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 链接卡 */
.link-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 163, 115, 0.08);
  display: flex;
  align-items: center;
}
.link-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}
.link-text {
  flex: 1;
  overflow: hidden;
}
.link-label {
  font-size: 24rpx;
  color: #A8A29E;
  margin-bottom: 6rpx;
}
.link-url {
  font-size: 26rpx;
  color: #0891B2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.link-action {
  padding: 12rpx 28rpx;
  background: #FDF6ED;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #D4A373;
}
