<!-- 童行小程序 - 场馆指南列表页 -->
<view class="venues-page">

  <!-- 搜索栏 -->
  <view class="search-bar">
    <image class="search-icon" src="/assets/search-icon.png" mode="aspectFit" />
    <input class="search-input" type="text" placeholder="搜索场馆名称、地址或关键词" value="{{searchQuery}}" bindinput="onSearchInput" confirm-type="search" />
  </view>

  <!-- 城市筛选 -->
  <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-list">
      <view wx:for="{{cities}}" wx:key="key" class="filter-chip {{cityFilter === item.key ? 'active' : ''}}" bindtap="onCityTap" data-key="{{item.key}}">
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 类型筛选 -->
  <scroll-view class="filter-scroll type-filter" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-list">
      <view wx:for="{{types}}" wx:key="key" class="filter-chip {{typeFilter === item.key ? 'active' : ''}}" bindtap="onTypeTap" data-key="{{item.key}}">
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 统计条 -->
  <view class="stats-bar">
    <text>共 {{venues.length}} 个场馆</text>
    <text wx:if="{{cityFilter !== 'all'}}" class="stats-city">· {{cityFilter === 'shenzhen' ? '深圳' : cityFilter === 'guangzhou' ? '广州' : cityFilter === 'shanghai' ? '上海' : cityFilter === 'beijing' ? '北京' : cityFilter === 'hangzhou' ? '杭州' : cityFilter}}</text>
  </view>

  <!-- 场馆列表 -->
  <view class="venue-list" wx:if="{{venues.length > 0}}">
    <view wx:for="{{venues}}" wx:key="name" class="venue-card" bindtap="onVenueTap" data-name="{{item.name}}">
      <view class="venue-header">
        <view class="venue-name">{{item.name}}</view>
        <view class="venue-type">{{item.type}}</view>
      </view>
      <view wx:if="{{item.highlights && item.highlights.length > 0}}" class="venue-highlights">
        <view wx:for="{{item.highlights}}" wx:key="*this" wx:for-item="tag" class="highlight-tag">{{tag}}</view>
      </view>
      <view wx:if="{{item.address}}" class="venue-address">{{item.address}}</view>
      <view class="venue-footer">
        <view class="venue-fee">{{item.fee || '费用未知'}}</view>
        <view class="venue-count {{item.hasActivity ? 'has' : ''}}">
          {{item.hasActivity ? item.activityCount + ' 个近期活动' : '暂无活动 · 场馆也值得逛'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 空态 -->
  <view class="empty-state" wx:if="{{!loading && venues.length === 0}}">
    <view class="empty-icon">🏛️</view>
    <view class="empty-text">没有找到符合条件的场馆</view>
    <view class="empty-hint">换个城市或类型试试</view>
  </view>

</view>
