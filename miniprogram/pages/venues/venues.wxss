/* 童行小程序 - 场馆指南列表页 */
.venues-page {
  min-height: 100vh;
  background-color: #FFFDF7;
  padding: 20rpx 24rpx 40rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #4A403A;
  height: 40rpx;
}

.filter-scroll {
  margin-bottom: 16rpx;
  white-space: nowrap;
}

.type-filter {
  margin-bottom: 20rpx;
}

.filter-list {
  display: inline-flex;
  padding-right: 24rpx;
}

.filter-chip {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #6B5D50;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.filter-chip.active {
  background: #D4A373;
  color: #FFFFFF;
}

.stats-bar {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #8C7E70;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.stats-city {
  margin-left: 8rpx;
}

.venue-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.venue-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.venue-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.venue-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #3D3229;
  flex: 1;
  margin-right: 16rpx;
  line-height: 1.4;
}

.venue-type {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  background: #F5E6D3;
  color: #A67B5B;
  font-size: 22rpx;
  border-radius: 12rpx;
}

.venue-highlights {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.highlight-tag {
  padding: 4rpx 14rpx;
  background: #FFF8F0;
  color: #C49A6C;
  font-size: 22rpx;
  border-radius: 10rpx;
}

.venue-address {
  font-size: 26rpx;
  color: #6B5D50;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.venue-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #F2EFE9;
  padding-top: 16rpx;
}

.venue-fee {
  font-size: 24rpx;
  color: #8C7E70;
}

.venue-count {
  font-size: 24rpx;
  color: #A8A29E;
}

.venue-count.has {
  color: #D4A373;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #6B5D50;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #A8A29E;
}
