/* pages/venues/venues.wxss */

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 顶部横幅 */
.header {
  background: linear-gradient(135deg, #D4A373 0%, #B8895A 100%);
  padding: 40rpx 32rpx 48rpx;
  color: white;
}
.header-title {
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.header-subtitle {
  font-size: 28rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}
.header-stats {
  margin-top: 20rpx;
  font-size: 24rpx;
  opacity: 0.7;
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  margin: 20rpx 24rpx 0;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 163, 115, 0.06);
}
.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #292524;
}
.search-clear {
  font-size: 30rpx;
  color: #A8A29E;
  padding: 0 8rpx;
}

/* 筛选栏 - 吸顶 */
.filter-bar {
  background: #FFFFFF;
  padding: 16rpx 24rpx 12rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(212, 163, 115, 0.06);
}
.filter-row {
  margin-bottom: 14rpx;
}
.filter-row:last-child {
  margin-bottom: 4rpx;
}
.filter-scroll {
  white-space: nowrap;
}
.filter-chips {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 4rpx;
}
.chip {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #F5E6D3;
  color: #78716C;
  white-space: nowrap;
  transition: all 0.2s;
}
.chip-sm {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  border-radius: 28rpx;
}
.chip-active {
  background: linear-gradient(135deg, #D4A373 0%, #B8895A 100%);
  color: white;
  font-weight: 600;
}

/* 场馆卡片 */
.venue-list {
  padding: 8rpx 0;
}
.venue-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 163, 115, 0.08);
  position: relative;
  transition: transform 0.15s;
}
.venue-card:active {
  transform: scale(0.98);
}
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #292524;
  line-height: 1.5;
  margin-bottom: 16rpx;
}
.card-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}
.card-icon {
  margin-right: 12rpx;
  font-size: 26rpx;
}
.card-text {
  font-size: 26rpx;
  color: #78716C;
  flex: 1;
}

/* 列表底部 */
.list-footer {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #A8A29E;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 32rpx;
  color: #78716C;
  margin-bottom: 12rpx;
}
.empty-hint {
  font-size: 26rpx;
  color: #A8A29E;
}
