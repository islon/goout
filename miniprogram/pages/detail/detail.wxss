/* pages/detail/detail.wxss */

.container {
  padding-bottom: 160rpx;
  min-height: 100vh;
}

/* 顶部信息卡 */
.hero-card {
  background: linear-gradient(135deg, #D4A373 0%, #B8895A 100%);
  padding: 48rpx 32rpx;
  color: white;
}
.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.hero-tags .tag {
  background: rgba(255, 255, 255, 0.2);
  color: white;
}
.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 20rpx;
}
.hero-status {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.15);
}
.status-active {
  background: rgba(220, 252, 231, 0.25);
}

/* 信息卡 */
.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 163, 115, 0.08);
}
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F5F0E8;
}
.info-row:last-child {
  border-bottom: none;
}
.info-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  margin-top: 4rpx;
}
.info-label {
  font-size: 24rpx;
  color: #A8A29E;
  margin-bottom: 6rpx;
}
.info-value {
  font-size: 30rpx;
  color: #292524;
}

/* 活动介绍 */
.desc-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 163, 115, 0.08);
}
.desc-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #292524;
  margin-bottom: 20rpx;
}
.desc-text {
  font-size: 28rpx;
  color: #78716C;
  line-height: 1.8;
}

/* 链接卡 */
.link-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 163, 115, 0.08);
  display: flex;
  align-items: center;
}
.link-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}
.link-text {
  flex: 1;
  overflow: hidden;
}
.link-label {
  font-size: 24rpx;
  color: #A8A29E;
  margin-bottom: 6rpx;
}
.link-url {
  font-size: 26rpx;
  color: #0891B2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.link-action {
  padding: 12rpx 28rpx;
  background: #FDF6ED;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #D4A373;
}

/* 底部订阅栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 12rpx rgba(212, 163, 115, 0.1);
  z-index: 100;
}
.subscribe-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #D4A373 0%, #B8895A 100%);
  color: white;
  border: none;
}
.subscribe-btn::after {
  border: none;
}
.subscribe-btn.subscribed {
  background: #DCFCE7;
  color: #166534;
}
