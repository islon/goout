/* 童行小程序 - 活动列表页样式 */

.page {
  min-height: 100vh;
  background: #FFFDF7;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 253, 247, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #E8E0D0;
  border-top: 6rpx solid #D4A373;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #A8A29E;
}

/* 搜索框 */
.search-bar {
  background: #FFFFFF;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #F5F0E8;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  flex: 1;
}

.search-icon {
  position: absolute;
  left: 20rpx;
  width: 36rpx;
  height: 36rpx;
  z-index: 1;
}

.search-input {
  width: 100%;
  padding: 20rpx 60rpx 20rpx 60rpx;
  border: 3rpx solid #E7DFD3;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: #FFFFFF;
  color: #292524;
}

.search-clear-img {
  position: absolute;
  right: 16rpx;
  width: 28rpx;
  height: 28rpx;
  padding: 8rpx;
}

/* 刷新按钮 */
.refresh-btn {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F0E8;
}

.refresh-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.refresh-btn.spinning .refresh-icon-img {
  animation: spin 0.8s linear infinite;
}

/* 数据更新时间 */
.update-info {
  padding: 8rpx 24rpx;
  font-size: 20rpx;
  color: #B8B0A0;
  background: #FFFDF7;
  text-align: right;
}

.empty-hint-banner {
  margin: 8rpx 24rpx 0;
  padding: 12rpx 20rpx;
  font-size: 22rpx;
  color: #8a6d3b;
  background: #FFF7E6;
  border-left: 6rpx solid #FFB84D;
  border-radius: 8rpx;
}

/* 筛选区 */
.filter-section {
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  border-bottom: 2rpx solid #F5F0E8;
}

.filter-label {
  font-size: 20rpx;
  color: #A8A29E;
  margin-bottom: 12rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-bar {
  display: inline-flex;
  gap: 12rpx;
  flex-wrap: nowrap;
}

.filter-bar[style*="flex-wrap"] {
  flex-wrap: wrap;
}

/* 修正 - 非滚动场景 */
.filter-section .filter-bar {
  flex-wrap: wrap;
}

.filter-scroll .filter-bar {
  flex-wrap: nowrap;
  display: inline-flex;
}

/* 地点筛选 - 展开状态换行布局 */
.filter-bar-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-bar-inline {
  display: inline-flex;
  flex-wrap: nowrap;
}

.filter-btn {
  display: inline-block;
  padding: 10rpx 24rpx;
  background: #FFFFFF;
  border: 3rpx solid #E7DFD3;
  border-radius: 40rpx;
  font-size: 22rpx;
  color: #78716C;
  white-space: nowrap;
  flex-shrink: 0;
  font-weight: 500;
  line-height: 1.5;
}

.filter-btn.active {
  background: linear-gradient(135deg, #D4A373 0%, #B8895A 100%);
  color: #FFFFFF;
  border-color: #D4A373;
  box-shadow: 0 4rpx 12rpx rgba(212, 163, 115, 0.3);
  font-weight: 600;
}

.filter-btn.disabled {
  opacity: 0.35;
}

.expand-toggle {
  text-align: center;
  font-size: 22rpx;
  color: #D4A373;
  padding: 12rpx 0 4rpx;
  font-weight: 500;
}

/* 统计信息 */
.count-info {
  text-align: center;
  font-size: 24rpx;
  color: #78716C;
  padding: 20rpx 0 12rpx;
}

/* 活动列表 */
.activity-list {
  padding: 0 24rpx;
}

.month-divider {
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
  margin: 24rpx 0 16rpx;
  padding-left: 4rpx;
}

/* 活动卡片 */
.activity-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(212, 163, 115, 0.06);
  border: 2rpx solid #F5F0E8;
  position: relative;
  overflow: hidden;
  transition: all 0.2s;
}

.activity-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(212, 163, 115, 0.12);
}

/* 日期 badge */
.date-badge {
  position: absolute;
  top: 0;
  right: 0;
  padding: 6rpx 20rpx;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 0 24rpx 0 16rpx;
}

.today-badge {
  background: #DC2626;
  color: #FFFFFF;
}

.tomorrow-badge {
  background: #CA8A04;
  color: #FFFFFF;
}

.upcoming-badge {
  background: #0891B2;
  color: #FFFFFF;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #292524;
  flex: 1;
  line-height: 1.4;
}

.card-badges {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  align-items: flex-end;
  flex-shrink: 0;
  padding-right: 60rpx;
}

.card-badges .badge {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}

.badge-free {
  background: #DCFCE7;
  color: #166534;
}

.badge-paid {
  background: #FEF3C7;
  color: #92400E;
}

.badge-type {
  background: #E0F2F7;
  color: #0891B2;
}

.badge-family {
  background: #FCE7F3;
  color: #9D174D;
}

.card-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 24rpx;
  color: #78716C;
  margin-bottom: 16rpx;
}

.meta-item {
  line-height: 1.5;
}

.card-desc {
  font-size: 25rpx;
  color: #57534E;
  line-height: 1.6;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.card-link {
  font-size: 24rpx;
  color: #D4A373;
  font-weight: 600;
  text-align: right;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #78716C;
}

.empty-hint {
  font-size: 24rpx;
  color: #A8A29E;
  margin-top: 12rpx;
}

/* 分页 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  margin: 32rpx 0 16rpx;
}

.page-btn {
  padding: 16rpx 36rpx;
  background: #FFFFFF;
  border: 2rpx solid #E7DFD3;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #292524;
  font-weight: 500;
}

.page-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.page-info {
  font-size: 26rpx;
  color: #78716C;
  font-weight: 600;
}
