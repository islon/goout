<!-- pages/index/index.wxml -->
<view class="container">

  <!-- 顶部横幅 -->
  <view class="header">
    <view class="header-title">童行</view>
    <view class="header-subtitle">全国亲子活动日历</view>
    <view class="header-stats">
      <text>共 {{filteredActivities.length}} 场活动</text>
    </view>
  </view>

  <!-- 筛选区 -->
  <view class="filter-bar">

    <!-- 城市（含杭州，与 Web 版一致） -->
    <view class="filter-row">
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-chips">
          <view
            class="chip {{activeCity === item ? 'chip-active' : ''}}"
            wx:for="{{cities}}" wx:key="*this"
            bindtap="onCityTap" data-value="{{item}}">{{item}}</view>
        </view>
      </scroll-view>
    </view>

    <!-- 时间维度（新增，对齐 Web 版） -->
    <view class="filter-row">
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-chips">
          <view
            class="chip chip-sm {{activeTime === item ? 'chip-active' : ''}}"
            wx:for="{{times}}" wx:key="*this"
            bindtap="onTimeTap" data-value="{{item}}">{{timeLabels[item]}}</view>
        </view>
      </scroll-view>
    </view>

    <!-- 快捷：免费 / 亲子 + 类型（横向滚动） -->
    <view class="filter-row filter-row-actions">
      <view class="quick-tags">
        <view
          class="action-btn {{activeFee === '免费' ? 'action-active' : ''}}"
          bindtap="onFeeTap" data-value="{{activeFee === '免费' ? '全部' : '免费'}}">免费</view>
        <view
          class="action-btn {{activeFamily === 'family' ? 'action-active' : ''}}"
          bindtap="onFamilyTap" data-value="{{activeFamily === 'family' ? 'all' : 'family'}}">亲子</view>
      </view>
      <scroll-view scroll-x class="filter-scroll flex-1" enhanced show-scrollbar="{{false}}">
        <view class="filter-chips">
          <view
            class="chip chip-sm {{activeCategory === item ? 'chip-active' : ''}}"
            wx:for="{{categories}}" wx:key="*this"
            bindtap="onCategoryTap" data-value="{{item}}">{{item}}</view>
        </view>
      </scroll-view>
    </view>

    <!-- 区县联动（仅选中具体城市时显示） -->
    <view class="district-panel" wx:if="{{activeCity !== '全部'}}">
      <scroll-view scroll-x class="filter-scroll" enhanced show-scrollbar="{{false}}">
        <view class="filter-chips">
          <view
            class="chip chip-xs {{activeDistrict === item ? 'chip-active' : ''}}"
            wx:for="{{districtOptions}}" wx:key="*this"
            bindtap="onDistrictTap" data-value="{{item}}">{{item}}</view>
        </view>
      </scroll-view>
    </view>

  </view>

  <!-- 活动列表 -->
  <view class="activity-list" wx:if="{{filteredActivities.length > 0}}">
    <view
      class="activity-card"
      wx:for="{{filteredActivities}}" wx:key="_id"
      bindtap="onActivityTap" data-id="{{item._id}}">

      <!-- 标签行 -->
      <view class="card-tags">
        <text class="tag tag-category">{{item.category}}</text>
        <text class="tag {{item._isFree ? 'tag-free' : 'tag-paid'}}">{{item.fee}}</text>
        <text class="tag tag-family" wx:if="{{item._isFamily}}">👶 亲子</text>
      </view>

      <!-- 标题 -->
      <view class="card-title">{{item.title}}</view>

      <!-- 日期 -->
      <view class="card-row">
        <text class="card-icon">📅</text>
        <text class="card-text">{{item._dateRange}}</text>
      </view>

      <!-- 地点 -->
      <view class="card-row">
        <text class="card-icon">📍</text>
        <text class="card-text">{{item.venue}}</text>
      </view>

      <!-- 城市+区县标记 -->
      <view class="card-city">{{item._cityName}}<text wx:if="{{item.district}}"> · {{item.district}}</text></view>
    </view>

    <!-- 列表底部 -->
    <view class="list-footer">
      <text>— 没有更多活动了 —</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredActivities.length === 0 && !loading}}">
    <view class="empty-icon">🔍</view>
    <view class="empty-text">没有符合条件的活动</view>
    <view class="empty-hint">试试调整筛选条件</view>
  </view>

</view>
