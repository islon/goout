<!-- 童行小程序 - 场馆详情页 -->
<view class="venue-page" wx:if="{{venue}}">

  <!-- 头部 -->
  <view class="venue-header">
    <view class="venue-name-row">
      <view class="venue-name" bindlongpress="onCopyText" data-text="{{venue.name}}">{{venue.name}}</view>
      <view class="venue-name-actions">
        <text class="venue-action-btn" bindtap="onCopyText" data-text="{{venue.name}}">复制</text>
        <text class="venue-action-btn primary" bindtap="onOpenMap">导航</text>
      </view>
    </view>
    <view class="venue-badges">
      <view class="badge badge-type">{{venue.type}}</view>
      <view class="badge badge-city">{{cityName}}</view>
      <view class="badge badge-fee">{{venue.fee || '费用未知'}}</view>
    </view>
  </view>

  <!-- 亮点 -->
  <view class="info-card" wx:if="{{hasHighlights}}">
    <view class="info-title">亮点</view>
    <view class="highlight-list">
      <view wx:for="{{venue.highlights}}" wx:key="*this" class="highlight-tag">{{item}}</view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="info-card">
    <view class="info-title">基本信息</view>
    <view wx:if="{{hasAddress}}" class="info-row">
      <view class="info-label">地址</view>
      <view class="info-value">
        <text class="addr-text" bindlongpress="onCopyText" data-text="{{venue.address}}">{{venue.address}}</text>
        <view class="addr-actions">
          <text wx:if="{{hasCoords}}" class="copy-link" bindtap="onCopyText" data-text="{{venue.address}}">复制</text>
          <text class="map-link" bindtap="onOpenMap">导航</text>
        </view>
      </view>
    </view>
    <view wx:if="{{hasTransport}}" class="info-row">
      <view class="info-label">交通</view>
      <view class="info-value">{{venue.transport}}</view>
    </view>
    <view wx:if="{{venue.fee}}" class="info-row">
      <view class="info-label">门票</view>
      <view class="info-value">{{venue.fee}}</view>
    </view>
  </view>

  <!-- 场馆介绍 -->
  <view class="info-card" wx:if="{{hasDescription}}">
    <view class="info-title">场馆介绍</view>
    <view class="info-desc">{{venue.description}}</view>
  </view>

  <!-- 核验链接 -->
  <view class="link-section" wx:if="{{hasLinks}}">
    <view class="link-title">🔗 核验链接</view>
    <view wx:for="{{links}}" wx:key="url" class="link-card">
      <view class="link-label">{{item.label}}</view>
      <view class="link-url">{{item.url}}</view>
      <button class="link-copy-btn" bindtap="onCopyLink" data-url="{{item.url}}">复制链接</button>
    </view>
    <view class="link-hint">复制后在浏览器中打开查看详情</view>
  </view>

  <!-- 该场馆的活动 -->
  <view class="activities-section" wx:if="{{hasActivities}}">
    <view class="section-title">近期活动</view>
    <view class="activity-list">
      <view wx:for="{{activities}}" wx:key="cardId" class="activity-item" bindtap="onActivityTap" data-id="{{item.cardId}}">
        <view class="activity-title">{{item.name}}</view>
        <view class="activity-meta">
          <text class="activity-date">{{item.dateDisplay}}</text>
          <text wx:if="{{item.category || item.type}}" class="activity-type">{{item.category || item.type}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 无活动提示 -->
  <view class="empty-tip" wx:if="{{!hasActivities}}">
    <image class="empty-icon" src="/assets/about-cal.png" mode="aspectFit"></image>
    <view class="empty-title">暂无近期活动</view>
    <view class="empty-desc">场馆本身就值得逛逛</view>
  </view>

  <!-- 反馈入口 -->
  <view class="feedback-bar" bindtap="onFeedbackTap">
    <view class="feedback-text">信息有误或想补充？</view>
    <view class="feedback-action">提交反馈</view>
  </view>

  <!-- 分享入口 -->
  <view class="share-section">
    <button class="share-btn" open-type="share">
      <image class="share-icon" src="/assets/about-share.png" mode="aspectFit"></image>
      <text class="share-text">分享给朋友</text>
    </button>
  </view>

  <view style="height: 60rpx;"></view>
</view>
