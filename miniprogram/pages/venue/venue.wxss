/* 童行小程序 - 场馆详情页 */
.venue-page {
  min-height: 100vh;
  background-color: #FFFDF7;
  padding: 24rpx 24rpx 40rpx;
}

.venue-header {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.venue-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #3D3229;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.venue-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.badge-type {
  background: #F5E6D3;
  color: #A67B5B;
}

.badge-city {
  background: #E8F4E9;
  color: #5B9A6B;
}

.badge-fee {
  background: #FFF3E0;
  color: #D4A373;
}

.info-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.info-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3229;
  margin-bottom: 20rpx;
}

.highlight-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.highlight-tag {
  padding: 8rpx 18rpx;
  background: #FFF8F0;
  color: #C49A6C;
  font-size: 24rpx;
  border-radius: 12rpx;
}

.info-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F2ED;
}

.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-label {
  width: 100rpx;
  font-size: 26rpx;
  color: #8C7E70;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #4A403A;
  line-height: 1.5;
}

.copy-link {
  display: inline-block;
  margin-left: 16rpx;
  color: #D4A373;
  font-size: 24rpx;
}

.info-desc {
  font-size: 28rpx;
  color: #4A403A;
  line-height: 1.8;
}

.link-section {
  margin-bottom: 24rpx;
}

.link-btn {
  background: #FFFFFF;
  color: #D4A373;
  border: 1rpx solid #D4A373;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 16rpx 0;
}

.link-btn::after {
  border: none;
}

.link-hint {
  text-align: center;
  font-size: 22rpx;
  color: #A8A29E;
  margin-top: 12rpx;
}

.activities-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3229;
  margin-bottom: 20rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.activity-title {
  font-size: 28rpx;
  color: #3D3229;
  font-weight: 500;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.activity-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

.activity-date {
  color: #8C7E70;
}

.activity-type {
  padding: 4rpx 12rpx;
  background: #F5E6D3;
  color: #A67B5B;
  border-radius: 10rpx;
  font-size: 22rpx;
}

.empty-tip {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #6B5D50;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #A8A29E;
  line-height: 1.5;
}

.feedback-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.feedback-text {
  font-size: 26rpx;
  color: #6B5D50;
}

.feedback-action {
  font-size: 26rpx;
  color: #D4A373;
  font-weight: 500;
}
