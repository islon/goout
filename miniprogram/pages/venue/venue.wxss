/* 童行小程序 - 场馆详情页 */
.venue-page {
  min-height: 100vh;
  background-color: #FFFDF7;
  padding: 24rpx 24rpx 40rpx;
}

.venue-header {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.venue-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #3D3229;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.venue-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.badge-type {
  background: #F5E6D3;
  color: #A67B5B;
}

.badge-city {
  background: #E8F4E9;
  color: #5B9A6B;
}

.badge-fee {
  background: #FFF3E0;
  color: #D4A373;
}

.info-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.info-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3229;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #D4A373;
  padding-left: 16rpx;
}

.highlight-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.highlight-tag {
  padding: 8rpx 18rpx;
  background: #FFF8F0;
  color: #C49A6C;
  font-size: 24rpx;
  border-radius: 12rpx;
}

.info-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F2ED;
}

.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-label {
  width: 100rpx;
  font-size: 26rpx;
  color: #8C7E70;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #4A403A;
  line-height: 1.5;
}

.copy-link {
  display: inline-block;
  margin-left: 16rpx;
  color: #D4A373;
  font-size: 24rpx;
}

/* 地址相关操作（复制/导航） */
.addr-text {
  display: block;
  margin-bottom: 8rpx;
}

.addr-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.addr-actions .copy-link,
.map-link {
  display: inline-block;
  margin-left: 0;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  border-radius: 8rpx;
  line-height: 1.6;
}

.addr-actions .copy-link {
  color: #D4A373;
  background: #FFF8F0;
  border: 1rpx solid #E8D5BC;
}

.map-link {
  color: #0891B2;
  background: #E0F2F7;
  border: 1rpx solid #B9E4F0;
}

.info-desc {
  font-size: 28rpx;
  color: #4A403A;
  line-height: 1.8;
}

.link-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.link-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3229;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #D4A373;
  padding-left: 16rpx;
}

.link-card {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  margin-bottom: 12rpx;
  background: #FAFAF8;
  border-radius: 12rpx;
  border: 1rpx solid #F0ECE5;
}

.link-card:last-child {
  margin-bottom: 16rpx;
}

.link-label {
  font-size: 24rpx;
  color: #D4A373;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.link-url {
  font-size: 22rpx;
  color: #78716C;
  word-break: break-all;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.link-copy-btn {
  align-self: flex-start;
  padding: 8rpx 24rpx;
  font-size: 22rpx;
  color: #D4A373;
  background: #FFF8F0;
  border: 1rpx solid #E8D5BC;
  border-radius: 8rpx;
  line-height: 1.4;
}

.link-copy-btn::after {
  border: none;
}

.link-hint {
  text-align: center;
  font-size: 22rpx;
  color: #A8A29E;
  margin-top: 8rpx;
}

.activities-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D3229;
  margin-bottom: 20rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.activity-title {
  font-size: 28rpx;
  color: #3D3229;
  font-weight: 500;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.activity-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

.activity-date {
  color: #8C7E70;
}

.activity-type {
  padding: 4rpx 12rpx;
  background: #F5E6D3;
  color: #A67B5B;
  border-radius: 10rpx;
  font-size: 22rpx;
}

.empty-tip {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  width: 110rpx;
  height: 110rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #6B5D50;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #A8A29E;
  line-height: 1.5;
}

.feedback-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.feedback-text {
  font-size: 26rpx;
  color: #6B5D50;
}

.feedback-action {
  font-size: 26rpx;
  color: #D4A373;
  font-weight: 500;
}

/* 分享入口 */
.share-section {
  margin-bottom: 20rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #FCD34D 0%, #F59E0B 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.25);
  width: 100%;
}

.share-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.share-btn::after {
  border: none;
}

.share-icon {
  width: 48rpx;
  height: 48rpx;
}

.share-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #92400E;
}
