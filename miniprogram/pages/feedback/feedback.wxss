/* 童行小程序 - 反馈页 */
.feedback-page {
  min-height: 100vh;
  background-color: #FFFDF7;
  padding: 24rpx 24rpx 60rpx;
}

.feedback-tip {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #57534E;
  line-height: 1.6;
}

.form-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D3229;
  margin-bottom: 20rpx;
}

.category-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.category-item {
  padding: 20rpx 16rpx;
  background: #FAFAF8;
  border: 2rpx solid #EDEAE4;
  border-radius: 16rpx;
  text-align: center;
}

.category-item.active {
  background: #FFF8F0;
  border-color: #D4A373;
}

.category-name {
  font-size: 28rpx;
  color: #3D3229;
  margin-bottom: 6rpx;
}

.category-item.active .category-name {
  color: #D4A373;
  font-weight: 600;
}

.category-desc {
  font-size: 22rpx;
  color: #A8A29E;
}

.content-input {
  width: 100%;
  min-height: 240rpx;
  padding: 20rpx;
  background: #FAFAF8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #4A403A;
  line-height: 1.6;
  box-sizing: border-box;
}

.content-hint {
  text-align: right;
  font-size: 22rpx;
  color: #A8A29E;
  margin-top: 12rpx;
}

.contact-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #FAFAF8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #4A403A;
  box-sizing: border-box;
}

.copy-section {
  margin-bottom: 24rpx;
}

.copy-btn {
  text-align: center;
  padding: 24rpx 0;
  background: #FFFFFF;
  color: #D4A373;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.copy-hint {
  text-align: center;
  font-size: 22rpx;
  color: #A8A29E;
  margin-top: 12rpx;
}

.submit-section {
  margin-bottom: 32rpx;
}

.submit-btn {
  width: 100%;
  padding: 26rpx 0;
  background: #D4A373;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(212, 163, 115, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-hint {
  text-align: center;
  font-size: 22rpx;
  color: #A8A29E;
  margin-top: 16rpx;
  line-height: 1.5;
}

.other-section {
  margin-top: 24rpx;
}

.other-title {
  font-size: 26rpx;
  color: #8C7E70;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.other-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.other-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.other-content {
  flex: 1;
}

.other-name {
  font-size: 28rpx;
  color: #3D3229;
  margin-bottom: 6rpx;
}

.other-desc {
  font-size: 22rpx;
  color: #8C7E70;
}

.other-action {
  font-size: 24rpx;
  color: #D4A373;
  flex-shrink: 0;
}
