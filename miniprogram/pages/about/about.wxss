/* 童行小程序 - 订阅日程页样式 */

.about-page {
  min-height: 100vh;
  background: #FFFDF7;
  padding-bottom: 60rpx;
}

/* 头部 */
.about-header {
  background: linear-gradient(135deg, #D4A373 0%, #B8895A 100%);
  padding: 60rpx 40rpx 48rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.header-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 12rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.header-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 通用 section */
.section {
  padding: 32rpx 24rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #292524;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #D4A373;
  padding-left: 16rpx;
}

/* 提示文字 */
.subscribe-tip {
  font-size: 24rpx;
  color: #78716C;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

/* 微信提醒卡片 */
.remind-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #E0F2F7 0%, #DCFCE7 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  border: 2rpx solid #B9E4F0;
}

.remind-icon {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
}

.remind-text {
  flex: 1;
}

.remind-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
  margin-bottom: 6rpx;
}

.remind-desc {
  font-size: 24rpx;
  color: #57534E;
  line-height: 1.5;
}

/* 平台说明卡片 */
.platform-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #F5F0E8;
  box-shadow: 0 2rpx 8rpx rgba(212, 163, 115, 0.04);
}

.platform-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.platform-icon {
  width: 44rpx;
  height: 44rpx;
}

.platform-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
}

.platform-steps {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.step {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  font-size: 24rpx;
  color: #57534E;
  line-height: 1.6;
}

.step-num {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: linear-gradient(135deg, #D4A373 0%, #B8895A 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 50%;
}

.platform-note {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  background: #FFF8F0;
  border: 1rpx solid #F5E4D0;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #92400E;
  line-height: 1.6;
}

/* 订阅链接列表 */
.subscribe-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.subscribe-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #F5F0E8;
  box-shadow: 0 2rpx 6rpx rgba(212, 163, 115, 0.04);
}

.subscribe-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.subscribe-city {
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
}

.subscribe-count {
  font-size: 22rpx;
  color: #A8A29E;
}

.subscribe-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #D4A373;
  font-weight: 500;
}

.action-icon {
  width: 30rpx;
  height: 30rpx;
}

/* H5 链接卡片 */
.h5-card, .h5-schedule-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #F5F0E8;
  margin-bottom: 12rpx;
}

.h5-icon {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
}

.h5-content {
  flex: 1;
}

.h5-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
  margin-bottom: 4rpx;
}

.h5-desc {
  font-size: 22rpx;
  color: #78716C;
  margin-bottom: 4rpx;
}

.h5-url {
  font-size: 22rpx;
  color: #A8A29E;
}

.h5-action {
  font-size: 24rpx;
  color: #D4A373;
  font-weight: 500;
  flex-shrink: 0;
}

/* 数据说明 */
.data-info {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  border: 2rpx solid #F5F0E8;
  margin-bottom: 20rpx;
}

.data-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 24rpx;
  line-height: 1.8;
  padding: 10rpx 0;
  border-bottom: 2rpx solid #F5F0E8;
}

.data-row:last-child {
  border-bottom: none;
}

.data-label {
  color: #A8A29E;
  width: 120rpx;
  flex-shrink: 0;
}

.data-value {
  color: #57534E;
  flex: 1;
}

.feedback-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.feedback-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid #F5F0E8;
}

.feedback-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feedback-content {
  flex: 1;
}

.feedback-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D3229;
  margin-bottom: 8rpx;
}

.feedback-desc {
  font-size: 24rpx;
  color: #8C7E70;
}

/* 微信反馈按钮 */
.feedback-wx-btn {
  background: #07C160;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  margin: 0 0 16rpx;
  padding: 0;
  line-height: 88rpx;
  height: 88rpx;
  border: none;
}

.feedback-wx-btn::after {
  border: none;
}

.feedback-action {
  font-size: 24rpx;
  color: #D4A373;
  font-weight: 500;
  flex-shrink: 0;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 56rpx 24rpx 0;
}

.footer-logo {
  width: 110rpx;
  height: 110rpx;
  margin-bottom: 14rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 163, 115, 0.15);
}

.footer-text {
  font-size: 26rpx;
  color: #D4A373;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.footer-sub {
  font-size: 22rpx;
  color: #A8A29E;
  margin-bottom: 28rpx;
}

/* 信息区：置于图标上方，精简展示 版本/更新/场馆 */
.footer-meta {
  text-align: center;
  margin-bottom: 28rpx;
}

.meta-line {
  display: block;
  font-size: 22rpx;
  color: #A8A29E;
  line-height: 1.9;
}

.meta-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  margin-left: 8rpx;
  font-weight: 600;
}

.meta-badge.ok {
  background: #E7F6EC;
  color: #166534;
}

.meta-badge.pending {
  background: #FEF3C7;
  color: #B45309;
}

.meta-badge.partial {
  background: #F0EDE8;
  color: #78716C;
}
