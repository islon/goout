/* 童行小程序 - 订阅日程页样式 */

.about-page {
  min-height: 100vh;
  background: #FFFDF7;
  padding-bottom: 60rpx;
}

/* 头部 */
.about-header {
  background: linear-gradient(135deg, #D4A373 0%, #B8895A 100%);
  padding: 60rpx 40rpx 48rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.header-icon {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.header-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 通用 section */
.section {
  padding: 32rpx 24rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #292524;
  margin-bottom: 20rpx;
}

/* 提示文字 */
.subscribe-tip {
  font-size: 24rpx;
  color: #78716C;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

/* 微信提醒卡片 */
.remind-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #E0F2F7 0%, #DCFCE7 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  border: 2rpx solid #B9E4F0;
}

.remind-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.remind-text {
  flex: 1;
}

.remind-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
  margin-bottom: 6rpx;
}

.remind-desc {
  font-size: 24rpx;
  color: #57534E;
  line-height: 1.5;
}

/* 平台说明卡片 */
.platform-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #F5F0E8;
  box-shadow: 0 2rpx 8rpx rgba(212, 163, 115, 0.04);
}

.platform-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.platform-icon {
  font-size: 36rpx;
}

.platform-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
}

.platform-steps {
  margin-left: 12rpx;
}

.step {
  font-size: 24rpx;
  color: #57534E;
  line-height: 2;
}

.platform-note {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #FEF3C7;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #92400E;
  line-height: 1.5;
}

/* 订阅链接列表 */
.subscribe-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.subscribe-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #F5F0E8;
  box-shadow: 0 2rpx 6rpx rgba(212, 163, 115, 0.04);
}

.subscribe-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.subscribe-city {
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
}

.subscribe-count {
  font-size: 22rpx;
  color: #A8A29E;
}

.subscribe-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #D4A373;
  font-weight: 500;
}

.action-icon {
  font-size: 24rpx;
}

/* H5 链接卡片 */
.h5-card, .h5-schedule-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #F5F0E8;
  margin-bottom: 12rpx;
}

.h5-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.h5-content {
  flex: 1;
}

.h5-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #292524;
  margin-bottom: 4rpx;
}

.h5-url {
  font-size: 22rpx;
  color: #A8A29E;
}

.h5-action {
  font-size: 24rpx;
  color: #D4A373;
  font-weight: 500;
  flex-shrink: 0;
}

/* 城市卡片 */
.city-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.city-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  width: calc(50% - 8rpx);
  box-shadow: 0 2rpx 8rpx rgba(212, 163, 115, 0.06);
  border: 2rpx solid #F5F0E8;
  box-sizing: border-box;
}

.city-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #292524;
  margin-bottom: 8rpx;
}

.city-stats {
  font-size: 22rpx;
  color: #78716C;
  margin-bottom: 8rpx;
}

.stat-divider {
  margin: 0 6rpx;
  color: #E7DFD3;
}

.city-status {
  font-size: 20rpx;
  font-weight: 600;
}

/* FAQ */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.faq-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #F5F0E8;
}

.faq-q {
  font-size: 26rpx;
  font-weight: 600;
  color: #292524;
  margin-bottom: 8rpx;
}

.faq-a {
  font-size: 24rpx;
  color: #78716C;
  line-height: 1.6;
}

/* 数据说明 */
.data-info {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  border: 2rpx solid #F5F0E8;
}

.data-row {
  font-size: 24rpx;
  color: #78716C;
  line-height: 1.8;
  padding: 8rpx 0;
  border-bottom: 2rpx solid #F5F0E8;
}

.data-row:last-child {
  border-bottom: none;
}

.venue-guide-card,
.feedback-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.venue-guide-icon,
.feedback-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.venue-guide-content,
.feedback-content {
  flex: 1;
}

.venue-guide-title,
.feedback-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D3229;
  margin-bottom: 8rpx;
}

.venue-guide-desc,
.feedback-desc {
  font-size: 24rpx;
  color: #8C7E70;
}

.venue-guide-action,
.feedback-arrow {
  font-size: 26rpx;
  color: #D4A373;
  font-weight: 500;
  flex-shrink: 0;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 48rpx 24rpx 0;
}

.footer-text {
  font-size: 26rpx;
  color: #D4A373;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.footer-sub {
  font-size: 22rpx;
  color: #A8A29E;
}
