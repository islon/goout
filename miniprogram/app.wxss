/* 全局样式 - 沿用童行 Web 版配色 */
page {
  background: #FFFDF7;
  color: #292524;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 色彩变量 */
.sand-primary { color: #D4A373; }
.sand-bg { background: #FDF6ED; }
.ocean-text { color: #0891B2; }
.forest-text { color: #166534; }
.text-secondary { color: #78716C; }
.text-muted { color: #A8A29E; }

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}
.tag-free {
  background: #DCFCE7;
  color: #166534;
}
.tag-paid {
  background: #FEF3C7;
  color: #CA8A04;
}
.tag-family {
  background: #E0F2F7;
  color: #0891B2;
}
.tag-category {
  background: #F5E6D3;
  color: #B8895A;
}

/* 卡片 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 163, 115, 0.08);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #D4A373 0%, #B8895A 100%);
  color: white;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}
.btn-primary::after {
  border: none;
}
